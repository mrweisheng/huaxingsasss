# ============================================
# 应用配置
# ============================================
APP_NAME=合同管理系统
APP_ENV=development
DEBUG=true
API_V1_STR=/api/v1
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# 数据库配置
# ============================================
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=contract_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=dev_password
DATABASE_URL=postgresql://admin:dev_password@localhost:5432/contract_db

# ============================================
# Redis配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ============================================
# Celery配置
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# AI服务配置（SiliconFlow - 纯文本任务）
# ============================================
SILICONFLOW_API_KEY=sk-xxxx-your-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct
SILICONFLOW_TEXT_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ============================================
# AI服务配置（阿里云百炼 - 视觉模型）
# ============================================
DASHSCOPE_API_KEY=sk-xxxx-your-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen3-vl-flash

# 可选：DeepSeek备用
DEEPSEEK_API_KEY=sk-xxxx-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 文件存储配置
# ============================================
UPLOAD_DIR=/data/contract-system
CONTRACT_UPLOAD_DIR=${UPLOAD_DIR}/contracts
RECEIPT_UPLOAD_DIR=${UPLOAD_DIR}/receipts
SCREENSHOT_UPLOAD_DIR=${UPLOAD_DIR}/screenshots
TEMP_UPLOAD_DIR=${UPLOAD_DIR}/temp

# 最大文件大小（字节）
MAX_FILE_SIZE=52428800  # 50MB

# ============================================
# CORS配置
# ============================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# ============================================
# 汇率配置
# ============================================
DEFAULT_EXCHANGE_RATE_HKD_CNY=0.92
DEFAULT_EXCHANGE_RATE_USD_CNY=7.25
