          overflow: 'hidden',
          borderLeft: rightPanelOpen ? '1px solid var(--border-light)' : 'none',
          transition: 'width 0.25s cubic-bezier(0.4, 0, 0.2, 1), min-width 0.25s cubic-bezier(0.4, 0, 0.2, 1)',
        }}>
          <div style={{
            padding: '10px 14px',
            borderBottom: '1px solid var(--border-light)',
            display: 'flex', alignItems: 'center', justifyContent: 'space-between',
            flexShrink: 0,
          }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: 6 }}>
              <Text style={{ fontSize: 12, fontWeight: 500, color: 'var(--text-primary)' }}>
                娲诲姩闈㈡澘
              </Text>
            </div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 2 }}>
              <Button
                type="text"
                size="small"
                icon={<PlusOutlined />}
                onClick={handleNewChat}
                title="鏂板璇?
                style={{ color: 'var(--text-tertiary)', padding: '0 4px', height: 22, fontSize: 10 }}
              />
              <Button
                type="text"
                size="small"
                icon={rightPanelOpen ? <RightOutlined /> : <LeftOutlined />}
                onClick={() => setRightPanelOpen(!rightPanelOpen)}
                style={{ color: 'var(--text-tertiary)', padding: '0 4px', height: 22, fontSize: 10 }}
              />
            </div>
          </div>

          {rightPanelOpen && (
            <div style={{ flex: 1, overflow: 'auto', padding: '8px 10px', minHeight: 0 }}>

              {/* 鈺愨晲鈺愨晲鈺愨晲 涓婂崐鍖猴細瀵硅瘽涓樉绀烘€濊€?宸ュ叿/鏁版嵁锛涢灞忔棤瀵硅瘽鏃舵樉绀?鏈夎叮鍗犱綅" 鈺愨晲鈺愨晲鈺愨晲 */}

              {/* 鈹€鈹€ 鎬濊€冮摼锛堜粎瀵硅瘽涓級鈹€鈹€ */}
              {hasMessages && lastAssistantMsg?.thoughts && lastAssistantMsg.thoughts.length > 0 && (
                <div style={{
                  padding: '8px 10px', borderRadius: 6, marginBottom: 8,
                  border: '1px solid var(--border-light)',
                  background: 'var(--bg-subtle)',
                }}>
                  <div style={{
                    display: 'flex', alignItems: 'center', gap: 6, marginBottom: 8,
                  }}>
                    <div style={{
                      width: 22, height: 22, borderRadius: 5,
                      background: 'var(--brand-primary-lighter)', color: 'var(--brand-primary)',
                      display: 'flex', alignItems: 'center', justifyContent: 'center',
                      fontSize: 11, flexShrink: 0,
                    }}>
                      鈿?                    </div>
                    <span style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-primary)' }}>鎬濊€冮摼</span>
                  </div>
                  {lastAssistantMsg.thoughts.map((step, i) => (
                    <div key={step.id} style={{
                      display: 'flex', alignItems: 'center', gap: 6,
                      padding: '3px 0', fontSize: 11, color: 'var(--text-secondary)',
                    }}>
                      <span style={{
                        width: 6, height: 6, borderRadius: '50%', flexShrink: 0,
                        background: step.status === 'done' ? 'var(--color-success)' : 'var(--brand-gold)',
                        opacity: step.status === 'running' ? 1 : 0.6,
                      }} />
                      {step.message}
                    </div>
                  ))}
                </div>
              )}

              {/* 鈹€鈹€ 宸ュ叿璋冪敤锛堜粎瀵硅瘽涓級鈹€鈹€ */}
              {hasMessages && lastAssistantMsg?.toolCalls && lastAssistantMsg.toolCalls.length > 0 && (
                <div style={{
                  padding: '8px 10px', borderRadius: 6, marginBottom: 8,
                  border: '1px solid var(--border-light)',
                  background: 'var(--bg-subtle)',
                }}>
                  <div style={{
                    display: 'flex', alignItems: 'center', gap: 6, marginBottom: 8,
                  }}>
                    <div style={{
                      width: 22, height: 22, borderRadius: 5,
                      background: 'var(--brand-gold-bg)', color: 'var(--brand-gold)',
                      display: 'flex', alignItems: 'center', justifyContent: 'center',
                      fontSize: 11, flexShrink: 0,
                    }}>
                      馃敡
                    </div>
                    <span style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-primary)' }}>宸ュ叿璋冪敤</span>
                  </div>
                  {lastAssistantMsg.toolCalls.map((tc, i) => (
                    <div key={tc.id} style={{
                      display: 'flex', alignItems: 'center', gap: 4,
                      padding: '2px 0', fontSize: 11,
                    }}>
                      <span style={{ color: tc.result ? 'var(--color-success)' : 'var(--brand-gold)', fontSize: 10 }}>
                        {tc.result ? '鉁? : '鈼?}
                      </span>
                      <span style={{
                        color: 'var(--text-secondary)',
                        fontFamily: 'var(--font-mono)', fontSize: 10,
                      }}>
                        {tc.name}
                      </span>
                    </div>
                  ))}
                </div>
              )}

              {/* 鈹€鈹€ 鏁版嵁寮曠敤锛堜粎瀵硅瘽涓級鈹€鈹€ */}
              {hasMessages && lastAssistantMsg?.toolCalls?.some(tc => tc.summary?.items?.length) && (
                <div style={{
                  padding: '8px 10px', borderRadius: 6, marginBottom: 8,
                  border: '1px solid var(--border-light)',
                  background: 'var(--bg-subtle)',
                }}>
                  <div style={{
                    display: 'flex', alignItems: 'center', gap: 6, marginBottom: 8,
                  }}>
                    <div style={{
                      width: 22, height: 22, borderRadius: 5,
                      background: 'var(--color-success-bg)', color: 'var(--color-success)',
                      display: 'flex', alignItems: 'center', justifyContent: 'center',
                      fontSize: 11, flexShrink: 0,
                    }}>
                      馃搳
                    </div>
                    <span style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-primary)' }}>鏁版嵁寮曠敤</span>
                  </div>
                  {lastAssistantMsg.toolCalls.filter(tc => tc.summary?.items?.length).map((tc) => (
                    <div key={tc.id}>
                      {tc.summary!.items.map((item, j) => (
                        <div key={j} style={{
                          display: 'flex', justifyContent: 'space-between',
                          padding: '2px 0', fontSize: 11,
                        }}>
                          <span style={{ color: 'var(--text-secondary)' }}>{item.label}</span>
                          <span style={{
                            color: item.highlight === 'warning' ? 'var(--color-danger)' : 'var(--text-primary)',
                            fontWeight: 500,
                          }}>
                            {item.value}
                          </span>
                        </div>
                      ))}
                    </div>
                  ))}
                </div>
              )}

              {/* 鈹€鈹€ 棣栧睆鏈夎叮鍗犱綅锛堜粎鏃犲璇濇椂锛夆攢鈹€ */}
              {!hasMessages && (
                <>
                  {/* 灏忔槦鐘舵€佸崱 */}
                  <div style={{
                    marginBottom: 8, padding: 10,
                    background: 'linear-gradient(135deg, #f0f4ff 0%, #faf5ff 100%)',
                    border: '1px solid #e0e7ff', borderRadius: 8,
                  }}>
                    <div style={{
                      width: 28, height: 28, borderRadius: '50%',
                      background: 'linear-gradient(135deg, var(--brand-gold), #e8b84b)',
                      display: 'flex', alignItems: 'center', justifyContent: 'center',
                      color: '#0f1a2e', fontSize: 12, fontWeight: 700,
                      marginBottom: 6,
                    }}>
                      <StarFilled />
                    </div>
                    <div style={{ fontSize: 11, color: 'var(--text-secondary)', lineHeight: 1.5 }}>
                      灏忔槦宸插氨缁紝<br />闅忔椂鍚綘宸仯 鉁?                    </div>
                    <div style={{ fontSize: 10, color: 'var(--text-tertiary)', marginTop: 4 }}>
                      鏈懆宸插府浣犲鐞?23 鍗?                    </div>
                  </div>

                  {/* 浠婃棩灏忚创澹?*/}
                  <div style={{
                    marginBottom: 8, padding: 10,
                    background: 'linear-gradient(135deg, #fdf8ef 0%, #fef6e6 100%)',
                    border: '1px solid var(--brand-gold-light)', borderRadius: 8,
                  }}>
                    <div style={{
                      fontSize: 11, fontWeight: 600, color: 'var(--brand-primary)',
                      marginBottom: 4, display: 'flex', alignItems: 'center', gap: 4,
                    }}>
                      馃挕 浠婃棩灏忚创澹?                    </div>
                    <div style={{ fontSize: 11, color: 'var(--text-secondary)', lineHeight: 1.5 }}>
                      璇曡瘯鎶婂皬鏄熷綋"鍚堝悓褰曞叆鍛?鈥斺€斾笂浼犲悎鍚?PDF锛屽墿涓嬬殑瀛楁瀹冨府浣犲～銆?                    </div>
                    <Button
                      size="small"
                      onClick={() => setSelectedTool('contract_entry')}
                      style={{
                        marginTop: 8, fontSize: 10, height: 22, padding: '0 10px',
                        background: 'var(--brand-primary)', color: '#fff',
                        border: 'none', borderRadius: 4,
                      }}
                    >
                      绔嬪嵆璇?鈫?                    </Button>
                  </div>

                  {/* 蹇嵎鎸囦护 */}
                  <div style={{
                    marginBottom: 8, padding: '8px 10px',
                    border: '1px solid var(--border-light)',
                    background: 'var(--bg-subtle)', borderRadius: 8,
                  }}>
                    <div style={{
                      display: 'flex', alignItems: 'center', gap: 6, marginBottom: 6,
                    }}>
                      <div style={{
                        width: 22, height: 22, borderRadius: 5,
                        background: 'var(--brand-primary-lighter)', color: 'var(--brand-primary)',
                        display: 'flex', alignItems: 'center', justifyContent: 'center',
                        fontSize: 11, flexShrink: 0,
                      }}>
                        鈿?                      </div>
                      <span style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-primary)' }}>蹇嵎鎸囦护</span>
                    </div>
                    {[
                      { icon: <FileTextOutlined />, text: '涓婁紶鍚堝悓', bg: '#e8edf5', fg: '#1e3a5f' },
                      { icon: <CreditCardOutlined />, text: '鐧昏鏀跺叆', bg: '#edfaf8', fg: '#0d9488' },
                      { icon: <DollarOutlined />, text: '鐧昏鏀嚭', bg: '#fef2f2', fg: '#dc2626' },
                      { icon: <FileSearchOutlined />, text: '鏌ヨ鍚堝悓', bg: '#fdf8ef', fg: '#c9952b' },
                      { icon: <BarChartOutlined />, text: '鏁版嵁姒傝', bg: '#f3f4f6', fg: '#475569' },
                    ].map((cmd, i) => (
                      <div
                        key={i}
                        onClick={() => onSendShortcut(cmd.text)}
                        style={{
                          display: 'flex', alignItems: 'center', gap: 6,
                          padding: '4px 4px', borderRadius: 4, fontSize: 11,
                          color: 'var(--text-secondary)', cursor: 'pointer',
                          transition: 'background 0.15s',
                        }}
                        onMouseEnter={(e) => { e.currentTarget.style.background = '#fff' }}
                        onMouseLeave={(e) => { e.currentTarget.style.background = 'transparent' }}
                      >
                        <span style={{
                          width: 18, height: 18, borderRadius: 4,
                          background: cmd.bg, color: cmd.fg,
                          display: 'flex', alignItems: 'center', justifyContent: 'center',
                          fontSize: 10, flexShrink: 0,
                        }}>
                          {cmd.icon}
                        </span>
                        {cmd.text}
                      </div>
                    ))}
                  </div>
                </>
              )}

              {/* 鈺愨晲鈺愨晲鈺愨晲 涓嬪崐鍖猴細鍘嗗彶浼氳瘽锛堝彲鎶樺彔锛岄粯璁ゆ敹璧凤級 鈺愨晲鈺愨晲鈺愨晲 */}
              <div style={{
                border: '1px solid var(--border-light)',
                borderRadius: 8, background: '#fff', overflow: 'hidden',
              }}>
                <div
                  onClick={() => setHistoryCollapsed(!historyCollapsed)}
                  style={{
                    padding: '7px 10px',
                    display: 'flex', alignItems: 'center', gap: 6,
                    cursor: 'pointer', userSelect: 'none',
                    background: 'var(--bg-subtle)',
                    fontSize: 11, fontWeight: 600, color: 'var(--text-primary)',
                  }}
                >
                  <span style={{
                    fontSize: 10, color: 'var(--text-tertiary)',
                    display: 'inline-flex', transition: 'transform 0.2s',
                    transform: historyCollapsed ? 'rotate(0deg)' : 'rotate(90deg)',
                  }}>
                    鈻?                  </span>
                  <span>鍘嗗彶浼氳瘽</span>
                  <span style={{ marginLeft: 'auto', fontSize: 10, color: 'var(--text-tertiary)', fontWeight: 400 }}>
                    {sessions.length} 鏉?                  </span>
                </div>

                {!historyCollapsed && (
                  <div style={{ padding: 4, maxHeight: 260, overflow: 'auto' }}>
                    {sessions.length === 0 ? (
                      <div style={{ textAlign: 'center', padding: '12px 8px', color: 'var(--text-tertiary)', fontSize: 11 }}>
                        鏆傛棤鍘嗗彶浼氳瘽
                      </div>
                    ) : (
                      sessions.map((session) => {
                        const isActive = session.sessionId === currentSessionId
                        const isHovered = hoveredSession === session.sessionId
                        return (
                          <div
                            key={session.sessionId}
                            onClick={() => handleClickSession(session.sessionId)}
                            onMouseEnter={() => setHoveredSession(session.sessionId)}
                            onMouseLeave={() => setHoveredSession(null)}
                            style={{
                              padding: '5px 8px', borderRadius: 5,
                              cursor: 'pointer', marginBottom: 1,
                              background: isActive
                                ? 'var(--brand-gold-bg)'
                                : isHovered
                                  ? 'var(--bg-subtle)'
                                  : 'transparent',
                              border: isActive ? '1px solid var(--brand-gold-light)' : '1px solid transparent',
                              position: 'relative',
                            }}
                          >
                            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', gap: 4 }}>
                              <Text style={{
                                fontSize: 11,
                                fontWeight: isActive ? 600 : 400,
                                color: isActive ? 'var(--brand-primary)' : 'var(--text-primary)',
                                display: 'block',
                                overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap',
                                flex: 1, minWidth: 0,
                              }}>
                                {session.title || '鏂板璇?}
                              </Text>
                              <DeleteOutlined
                                onClick={(e) => handleDeleteSession(session.sessionId, e)}
                                style={{
                                  fontSize: 10,
                                  color: isHovered ? 'var(--text-tertiary)' : 'transparent',
                                  padding: 2, flexShrink: 0,
                                  cursor: 'pointer', transition: 'color 0.15s',
                                }}
                                onMouseEnter={(ev) => { ev.currentTarget.style.color = 'var(--color-danger)' }}
                                onMouseLeave={(ev) => {
                                  ev.currentTarget.style.color = isHovered ? 'var(--text-tertiary)' : 'transparent'
                                }}
                              />
                            </div>
                            <div style={{ display: 'flex', gap: 4, marginTop: 1 }}>
                              <span style={{ fontSize: 9, color: 'var(--text-tertiary)' }}>
                                {formatSessionTime(session.createdAt)}
                              </span>
                              {session.messageCount != null && (
                                <span style={{ fontSize: 9, color: 'var(--text-tertiary)' }}>
                                  路 {session.messageCount} 鏉?                                </span>
                              )}
                            </div>
                          </div>
                        )
                      })
                    )}
                  </div>
                )}
              </div>

            </div>
          )}
        </div>
